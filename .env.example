TELEGRAM_BOT_TOKEN=        # from @BotFather
DATABASE_URL=              # PostgreSQL connection string (Railway Postgres sets this automatically)
DATABASE_SSL=              # set to "false" for local Postgres without SSL; Railway: leave unset
DAILY_TIME=07:30           # default daily nudge time for new accounts (24h HH:MM)
CHECKIN_TIME=20:00         # default evening check-in for new accounts (24h HH:MM)
STALL_DAYS=4               # default stall threshold for new accounts
TZ=America/Chicago         # default timezone for new accounts
ANTHROPIC_API_KEY=         # enables the web "Assistant" AI chat agent; leave blank to disable
ANTHROPIC_MODEL=claude-sonnet-4-6   # model for the AI agent (override if needed)
SEED_DEMO_DATA=            # local default: demo rows on new signup. Railway: never (set true to force)
PORT=3000                  # web dashboard port (Railway sets this automatically)
